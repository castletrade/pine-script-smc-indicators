//@version=5
indicator("Kill Zone Liquidity Sweeps - Castle Trade", overlay=true)

// --- Session Definitions (UTC) ---
is_asian_session  = time(timeframe.period, "1900-0300:1234567")
is_london_session = time(timeframe.period, "0800-1100:1234567")
is_newyork_session = time(timeframe.period, "1300-1600:1234567")

// --- State Tracking ---
var float asian_high = na
var float asian_low = na

if is_asian_session
    if na(asian_high) or high > asian_high
        asian_high := high
    if na(asian_low) or low < asian_low
        asian_low := low
else
    // Check for Sweep during London
    if is_london_session
        if high > asian_high[1] and close < asian_high[1]
            label.new(bar_index, high, "Liquidity Sweep (Asian High)", color=color.red, textcolor=color.white, style=label.style_label_down)
        if low < asian_low[1] and close > asian_low[1]
            label.new(bar_index, low, "Liquidity Sweep (Asian Low)", color=color.green, textcolor=color.white, style=label.style_label_up)

// Visualizing Session Extensions
plot(is_asian_session ? asian_high : na, "Asian High", color.gray, style=plot.style_linebr)
plot(is_asian_session ? asian_low : na, "Asian Low", color.gray, style=plot.style_linebr)
